{
  "buildCommand": "pnpm --filter @workspace/uber-rentals run build",
  "outputDirectory": "artifacts/uber-rentals/dist",
  "installCommand": "git lfs pull --include='artifacts/uber-rentals/public/car-sport-1.glb,artifacts/uber-rentals/public/car-sport-2.glb,artifacts/uber-rentals/public/car-sport-3.glb' && pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
